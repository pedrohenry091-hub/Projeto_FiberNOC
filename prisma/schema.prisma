generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Onu {
  id     Int    @id @default(autoincrement())
  nome   String
  mac    String @unique
  status String
  sinal  Float
  regiao String
  olt    String
  pon    String
}

model Log {
  id      Int    @id @default(autoincrement())
  data    String
  onu     String
  evento  String
  detalhe String
  tipo    String
}

model User {
  id        Int    @id @default(autoincrement())
  username  String @unique
  password  String
  role      String @default("user")
  createdAt String @default("")
}
